{
  "name": "tdd",
  "description": "Test-first pipeline: plan \u2192 design \u2192 generate tests \u2192 build \u2192 test \u2192 review \u2192 PR",
  "defaults": {
    "model": "sonnet",
    "agents": 1
  },
  "tdd": true,
  "intelligence": {
    "adversarial_enabled": true,
    "architecture_enabled": true,
    "simulation_enabled": true
  },
  "stages": [
    {
      "id": "intake",
      "enabled": true,
      "gate": "auto",
      "config": {
        "timeout_seconds": 1800
      }
    },
    {
      "id": "plan",
      "enabled": true,
      "gate": "approve",
      "config": {
        "model": "opus",
        "timeout_seconds": 1800
      }
    },
    {
      "id": "design",
      "enabled": true,
      "gate": "approve",
      "config": {
        "model": "opus",
        "timeout_seconds": 1800
      }
    },
    {
      "id": "build",
      "enabled": true,
      "gate": "auto",
      "config": {
        "max_iterations": 20,
        "audit": true,
        "quality_gates": true,
        "timeout_seconds": 5400
      }
    },
    {
      "id": "test",
      "enabled": true,
      "gate": "auto",
      "config": {
        "coverage_min": 80,
        "timeout_seconds": 1800
      }
    },
    {
      "id": "review",
      "enabled": true,
      "gate": "approve",
      "config": {
        "timeout_seconds": 1800
      }
    },
    {
      "id": "compound_quality",
      "enabled": true,
      "gate": "auto",
      "config": {
        "adversarial": true,
        "negative": true,
        "e2e": true,
        "dod_audit": true,
        "max_cycles": 3,
        "audit_intensity": "auto",
        "compound_quality_blocking": true,
        "timeout_seconds": 1800
      }
    },
    {
      "id": "pr",
      "enabled": true,
      "gate": "approve",
      "config": {
        "wait_ci": false,
        "timeout_seconds": 1800
      }
    },
    {
      "id": "merge",
      "enabled": true,
      "gate": "approve",
      "config": {
        "merge_method": "squash",
        "wait_ci_timeout_s": 600,
        "auto_delete_branch": true,
        "auto_merge": false,
        "auto_approve": false,
        "timeout_seconds": 1800
      }
    },
    {
      "id": "deploy",
      "enabled": false,
      "gate": "approve",
      "config": {
        "timeout_seconds": 1800
      }
    }
  ]
}
