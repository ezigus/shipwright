{
  "name": "hotfix",
  "description": "Urgent production fixes: intake \u2192 build \u2192 test \u2192 PR (all auto, minimal iteration)",
  "defaults": {
    "model": "opus",
    "agents": 1
  },
  "intelligence": {
    "adversarial_enabled": true,
    "architecture_enabled": true,
    "simulation_enabled": true
  },
  "stages": [
    {
      "id": "intake",
      "enabled": true,
      "gate": "auto",
      "config": {
        "timeout_seconds": 1800
      }
    },
    {
      "id": "plan",
      "enabled": false,
      "gate": "auto",
      "config": {
        "timeout_seconds": 1800
      }
    },
    {
      "id": "build",
      "enabled": true,
      "gate": "auto",
      "config": {
        "max_iterations": 10,
        "audit": false,
        "quality_gates": false,
        "timeout_seconds": 5400
      }
    },
    {
      "id": "test",
      "enabled": true,
      "gate": "auto",
      "config": {
        "coverage_min": 0,
        "timeout_seconds": 1800
      }
    },
    {
      "id": "review",
      "enabled": false,
      "gate": "auto",
      "config": {
        "timeout_seconds": 1800
      }
    },
    {
      "id": "compound_quality",
      "enabled": true,
      "gate": "auto",
      "config": {
        "adversarial": true,
        "negative": true,
        "e2e": false,
        "dod_audit": true,
        "max_cycles": 1,
        "audit_intensity": "auto",
        "compound_quality_blocking": true,
        "timeout_seconds": 1800
      }
    },
    {
      "id": "pr",
      "enabled": true,
      "gate": "auto",
      "config": {
        "wait_ci": false,
        "timeout_seconds": 1800
      }
    },
    {
      "id": "deploy",
      "enabled": false,
      "gate": "auto",
      "config": {
        "timeout_seconds": 1800
      }
    },
    {
      "id": "validate",
      "enabled": false,
      "gate": "auto",
      "config": {
        "timeout_seconds": 1800
      }
    }
  ]
}
